{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Protocol",
  "type": "object",
  "required": [
    "pull_response",
    "update"
  ],
  "properties": {
    "pull_response": {
      "$ref": "#/definitions/PullResponse"
    },
    "update": {
      "$ref": "#/definitions/Update"
    }
  },
  "definitions": {
    "IpPrefix": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "V4"
          ],
          "properties": {
            "V4": {
              "$ref": "#/definitions/Ipv4Prefix"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "V6"
          ],
          "properties": {
            "V6": {
              "$ref": "#/definitions/Ipv6Prefix"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Ipv4Prefix": {
      "type": "object",
      "required": [
        "addr",
        "len"
      ],
      "properties": {
        "addr": {
          "type": "string",
          "format": "ipv4"
        },
        "len": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      }
    },
    "Ipv6Prefix": {
      "type": "object",
      "required": [
        "addr",
        "len"
      ],
      "properties": {
        "addr": {
          "type": "string",
          "format": "ipv6"
        },
        "len": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      }
    },
    "PathVector": {
      "type": "object",
      "required": [
        "destination",
        "path"
      ],
      "properties": {
        "destination": {
          "$ref": "#/definitions/Ipv6Prefix"
        },
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PullResponse": {
      "type": "object",
      "properties": {
        "tunnel": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/TunnelOrigin"
          },
          "uniqueItems": true
        },
        "underlay": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/PathVector"
          },
          "uniqueItems": true
        }
      }
    },
    "TunnelOrigin": {
      "type": "object",
      "required": [
        "boundary_addr",
        "overlay_prefix",
        "vni"
      ],
      "properties": {
        "boundary_addr": {
          "type": "string",
          "format": "ipv6"
        },
        "metric": {
          "default": 0,
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "overlay_prefix": {
          "$ref": "#/definitions/IpPrefix"
        },
        "vni": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "TunnelUpdate": {
      "type": "object",
      "required": [
        "announce",
        "withdraw"
      ],
      "properties": {
        "announce": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TunnelOrigin"
          },
          "uniqueItems": true
        },
        "withdraw": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TunnelOrigin"
          },
          "uniqueItems": true
        }
      }
    },
    "UnderlayUpdate": {
      "type": "object",
      "required": [
        "announce",
        "withdraw"
      ],
      "properties": {
        "announce": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathVector"
          },
          "uniqueItems": true
        },
        "withdraw": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathVector"
          },
          "uniqueItems": true
        }
      }
    },
    "Update": {
      "type": "object",
      "properties": {
        "tunnel": {
          "anyOf": [
            {
              "$ref": "#/definitions/TunnelUpdate"
            },
            {
              "type": "null"
            }
          ]
        },
        "underlay": {
          "anyOf": [
            {
              "$ref": "#/definitions/UnderlayUpdate"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}